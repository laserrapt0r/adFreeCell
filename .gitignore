# Dependencies
node_modules/
package-lock.json
yarn.lock

# Logs
*.log
npm-debug.log*

# OS / editor cruft
.DS_Store
Thumbs.db
desktop.ini
*~
.idea/
.vscode/
*.code-workspace
*.swp
*.swo

# Build / temp
dist/
build/
tmp/
.cache/

# Secrets — never commit tokens or credentials
.env
.env.*
*.pem
secrets.*

# Android signing keystores — NEVER commit these
*.jks
*.keystore
key.properties

# Android build output (regenerated by CI) — do not commit
*.aab
*.apk
